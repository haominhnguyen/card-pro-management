# === MONGODB ===
# Dùng MongoDB Atlas Cloud
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# === TELEGRAM BOT ===
# Token lấy từ @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# === GOOGLE SHEETS ===
# ID của Spreadsheet (Lấy từ URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
# File Service Account JSON (Đặt trong thư mục backend/config/google-service-account.json)
GOOGLE_APPLICATION_CREDENTIALS=./config/google-service-account.json

# === APP ===
PORT=3000

# === AUTH (JWT) ===
# Sinh chuỗi ngẫu nhiên 64 ký tự hex cho mỗi secret (KHÔNG dùng lại 2 giá trị giống nhau)
JWT_ACCESS_SECRET=replace_with_64_hex_random
JWT_REFRESH_SECRET=replace_with_another_64_hex_random
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Origin frontend được phép gọi API (phân tách bằng dấu phẩy nếu nhiều)
FRONTEND_ORIGIN=http://localhost:5173
# (Tùy chọn) username bot Telegram để tạo deep-link liên kết; bỏ trống sẽ tự lấy qua getMe()
TELEGRAM_BOT_USERNAME=

# === EMAIL / SMTP (quên mật khẩu) ===
# Dùng để gửi mã OTP đặt lại mật khẩu. Nếu BỎ TRỐNG, mã sẽ được ghi ra log server
# (chỉ dùng cho môi trường dev). Ví dụ Gmail: bật 2FA rồi tạo "App Password" 16 ký tự.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# true nếu dùng cổng 465 (TLS ngầm); để trống/false cho 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
# Địa chỉ hiển thị người gửi (mặc định lấy theo SMTP_USER)
MAIL_FROM=CardPro <your_email@gmail.com>
